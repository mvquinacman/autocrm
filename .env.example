# Copy to .env.local and fill in. Never commit real values.
#
# Local dev (supabase start) uses the public local-demo defaults:
#   VITE_SUPABASE_URL=http://127.0.0.1:54321
#   VITE_SUPABASE_ANON_KEY=<printed by `npx supabase start`>
#
# Hosted project values live in the Supabase dashboard → Settings → API.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Only needed to run scripts/seed-remote.ts (server-side, keep secret!).
# Put these in .env.remote (gitignored), not here.
# SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
